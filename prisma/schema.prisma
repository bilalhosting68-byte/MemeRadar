generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  EXTREME
}

enum PositionStatus {
  OPEN
  CLOSED
}

enum SignalDecisionType {
  OPENED
  SKIPPED
}

model TokenSignal {
  id              String           @id @default(cuid())
  tokenAddress    String
  pairAddress     String
  chain           String
  dex             String
  symbol          String
  name            String?
  priceUsd        Float?
  liquidityUsd    Float?
  marketCap       Float?
  volume5m        Float?
  volume1h        Float?
  buys5m          Int?
  sells5m         Int?
  pairCreatedAt   DateTime?
  url             String?
  rawData         Json
  createdAt       DateTime         @default(now())
  riskResults     RiskResult[]
  signalDecisions SignalDecision[]

  @@unique([tokenAddress, pairAddress], name: "tokenAddress_pairAddress")
  @@index([chain, dex])
  @@index([tokenAddress])
  @@index([pairAddress])
  @@index([createdAt])
}

model SignalDecision {
  id            String             @id @default(cuid())
  tokenSignalId String
  tokenSignal   TokenSignal        @relation(fields: [tokenSignalId], references: [id], onDelete: Cascade)
  decision      SignalDecisionType
  reasons       Json
  riskScore     Int
  riskLevel     RiskLevel
  passedFilters Boolean
  createdAt     DateTime           @default(now())

  @@index([tokenSignalId])
  @@index([decision])
  @@index([riskLevel])
  @@index([createdAt])
}

model RiskResult {
  id            String      @id @default(cuid())
  tokenSignalId String
  tokenSignal   TokenSignal @relation(fields: [tokenSignalId], references: [id], onDelete: Cascade)
  score         Int
  level         RiskLevel
  reasons       Json
  createdAt     DateTime    @default(now())

  @@index([tokenSignalId])
  @@index([level])
  @@index([createdAt])
}

model PaperPosition {
  id                  String         @id @default(cuid())
  tokenSignalId       String?
  tokenAddress        String
  pairAddress         String
  symbol              String
  status              PositionStatus @default(OPEN)
  riskScore           Int
  riskLevel           RiskLevel
  entryMarketCap      Float?
  entryLiquidityUsd   Float?
  entryPriceUsd       Float
  currentPriceUsd     Float
  exitPriceUsd        Float?
  virtualSizeUsd      Float
  tokenAmount         Float
  stopLossPercent     Float
  takeProfitPercent   Float
  trailingStopPercent Float?
  highestPriceUsd     Float
  pnlUsd              Float
  pnlPercent          Float
  closeReason         String?
  openedAt            DateTime       @default(now())
  closedAt            DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([status])
  @@index([riskLevel])
  @@index([tokenAddress, pairAddress])
  @@index([openedAt])
  @@index([closedAt])
}

model BotEvent {
  id        String   @id @default(cuid())
  type      String
  message   String
  metadata  Json
  createdAt DateTime @default(now())

  @@index([type])
  @@index([createdAt])
}
